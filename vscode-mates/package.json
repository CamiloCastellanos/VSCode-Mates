{
  "name": "vscode-mates",
  "displayName": "VSCode-Mates",
  "description": "Don't feel alone, add mates in your code editor.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vscode-mates.helloWorld",
        "title": "Hello World"
      }
    ],
    "themes": [
      {
        "label": "Mates Neon Night",
        "uiTheme": "vs-dark",
        "path": "./themes/mates-neon-color-theme.json"
      },
      {
        "label": "Mates Retro Terminal",
        "uiTheme": "vs-dark",
        "path": "./themes/mates-retro-color-theme.json"
      },
      {
        "label": "Mates Cartoon Morning",
        "uiTheme": "vs",
        "path": "./themes/mates-cartoon-color-theme.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.116.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}