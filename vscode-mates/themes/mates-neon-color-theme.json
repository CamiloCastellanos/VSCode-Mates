{
    "$schema": "vscode://schemas/color-theme",
    "name": " Mates Neon Night",
    "type": "dark",
    "colors": {
        "editor.background": "#0B0F1A",
        "editor.foreground": "#E6E9F2",
        "editorLineNumber.foreground": "#3C425A",
        "editorLineNumber.activeForeground": "#7EE7FF",
        "editorCursor.foreground": "#7EE7FF",
        "editor.selectionBackground": "#2A3152",
        "editor.inactiveSelectionBackground": "#1B2138",
        "editor.wordHighlightBackground": "#2E355A88",
        "editor.wordHighlightStrongBackground": "#4A56A888",
        "editor.findMatchBackground": "#FF5CA833",
        "editor.findMatchBorder": "#FF5CA8",
        "editor.findMatchHighlightBackground": "#FF5CA81A",
        "editor.currentLineBackground": "#12182A",
        "editorIndentGuide.background1": "#1E2438",
        "editorIndentGuide.activeBackground1": "#3C4A7A",
        "activityBar.background": "#0A0D17",
        "activityBar.foreground": "#7EE7FF",
        "activityBarBadge.background": "#FF5CA8",
        "activityBarBadge.foreground": "#FFFFFF",
        "sideBar.background": "#0E1322",
        "sideBar.foreground": "#C8D0E7",
        "sideBarSectionHeader.background": "#131A2D",
        "sideBarSectionHeader.foreground": "#7EE7FF",
        "sideBarTitle.foreground": "#FFFFFF",
        "titleBar.activeBackground": "#0A0D17",
        "titleBar.activeForeground": "#FFFFFF",
        "titleBar.inactiveBackground": "#0A0D17",
        "titleBar.inactiveForeground": "#7A839C",
        "statusBar.background": "#0A0D17",
        "statusBar.foreground": "#7EE7FF",
        "statusBar.debuggingBackground": "#FF5CA8",
        "statusBar.debuggingForeground": "#FFFFFF",
        "statusBar.noFolderBackground": "#0A0D17",
        "tab.activeBackground": "#131A2D",
        "tab.activeForeground": "#FFFFFF",
        "tab.inactiveBackground": "#0B0F1A",
        "tab.inactiveForeground": "#6C7490",
        "tab.border": "#0A0D17",
        "tab.activeBorderTop": "#7EE7FF",
        "panel.background": "#0B0F1A",
        "panel.border": "#1E2438",
        "panelTitle.activeForeground": "#7EE7FF",
        "panelTitle.inactiveForeground": "#6C7490",
        "terminal.background": "#0B0F1A",
        "terminal.foreground": "#E6E9F2",
        "terminalCursor.foreground": "#7EE7FF",
        "button.background": "#7EE7FF",
        "button.foreground": "#0B0F1A",
        "button.hoverBackground": "#A5F0FF",
        "input.background": "#131A2D",
        "input.foreground": "#E6E9F2",
        "input.border": "#27314D",
        "input.placeholderForeground": "#6C7490",
        "dropdown.background": "#131A2D",
        "dropdown.foreground": "#E6E9F2",
        "dropdown.border": "#27314D",
        "list.activeSelectionBackground": "#1F2A45",
        "list.activeSelectionForeground": "#FFFFFF",
        "list.hoverBackground": "#151D33",
        "scrollbarSlider.background": "#2A315288",
        "scrollbarSlider.hoverBackground": "#3A447088",
        "scrollbarSlider.activeBackground": "#4B58A888"
    },
    "tokenColors": [
        {
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#5B6485",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "string",
                "string.quoted"
            ],
            "settings": {
                "foreground": "#A8FF60"
            }
        },
        {
            "scope": [
                "constant.numeric"
            ],
            "settings": {
                "foreground": "#FFD166"
            }
        },
        {
            "scope": [
                "keyword",
                "storage",
                "storage.type"
            ],
            "settings": {
                "foreground": "#FF5CA8",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "entity.name.function",
                "support.function",
                "meta.function-call"
            ],
            "settings": {
                "foreground": "#7EE7FF"
            }
        },
        {
            "scope": [
                "entity.name.type",
                "entity.name.class",
                "support.class"
            ],
            "settings": {
                "foreground": "#C792FF"
            }
        },
        {
            "scope": [
                "variable",
                "identifier"
            ],
            "settings": {
                "foreground": "#E6E9F2"
            }
        },
        {
            "scope": [
                "variable.parameter"
            ],
            "settings": {
                "foreground": "#FFCB6B"
            }
        },
        {
            "scope": [
                "punctuation",
                "meta.brace"
            ],
            "settings": {
                "foreground": "#8A93B5"
            }
        },
        {
            "scope": [
                "invalid",
                "invalid.illegal"
            ],
            "settings": {
                "foreground": "#FFFFFF",
                "background": "#FF5370"
            }
        },
        {
            "scope": [
                "markup.heading"
            ],
            "settings": {
                "foreground": "#7EE7FF",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "markup.bold"
            ],
            "settings": {
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "markup.italic"
            ],
            "settings": {
                "fontStyle": "italic"
            }
        }
    ]
}